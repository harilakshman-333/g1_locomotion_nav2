# ── Display ──────────────────────────────────────────────────────────────────
# Set to your current DISPLAY value (run: echo $DISPLAY on host)
DISPLAY=:1

# ── ROS 2 ────────────────────────────────────────────────────────────────────
# All containers must share the same domain ID to see each other's topics.
ROS_DOMAIN_ID=42

# ── Robot mode ───────────────────────────────────────────────────────────────
# "sim"  → velocity bridge talks to Isaac Lab
# "real" → velocity bridge talks to Unitree SDK (SportClient)
ROBOT_MODE=sim

# ── Checkpoints ──────────────────────────────────────────────────────────────
# Host-side path; mounted read-only into containers that need it.
CHECKPOINT_PATH=./checkpoints

# ── Isaac Lab ─────────────────────────────────────────────────────────────────
# Number of parallel sim environments (use 1 for interactive nav demo)
NUM_ENVS=1

# ── Nav2 ─────────────────────────────────────────────────────────────────────
# Path inside the ros2-nav container where saved maps are stored
MAP_SAVE_DIR=/maps
