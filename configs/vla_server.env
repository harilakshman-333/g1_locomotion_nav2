# vla_server.env
# Source this file before running the VLA inference server.
# Usage: source configs/vla_server.env && bash scripts/run_server_vla.sh

# === Paths ===
# Absolute path to the cloned unifolm-vla repository
VLA_REPO_DIR="$HOME/unifolm-vla"

# Absolute path to the VLM backbone checkpoint (UnifoLM-VLM-Base)
VLM_PRETRAINED_PATH="$(pwd)/checkpoints/UnifoLM-VLM-Base"

# Absolute path to the fine-tuned VLA checkpoint (UnifoLM-VLA-Base)
# Replace with UnifoLM-VLA-LIBERO if evaluating LIBERO tasks instead.
CKPT_PATH="$(pwd)/checkpoints/UnifoLM-VLA-Base"

# === Server ===
SERVER_PORT=8000

# === Normalization ===
# Must match the dataset the checkpoint was trained on.
# For UnifoLM-VLA-Base use "unitree_g1", for LIBERO use "libero_goal".
UNNORM_KEY="unitree_g1"
