# wma_server.env
# Source this file before running the WMA inference server.
# Usage: source configs/wma_server.env && bash scripts/run_server_wma.sh

# === Paths ===
# Absolute path to the cloned unifolm-world-model-action repository
WMA_REPO_DIR="$HOME/unifolm-world-model-action"

# Absolute path to the WMA checkpoint
# UnifoLM-WMA-0-Dual is fine-tuned on 5 Unitree G1/Z1 datasets.
CKPT_PATH="$(pwd)/checkpoints/UnifoLM-WMA-0-Dual"

# Directory to save inference results (videos, actions)
RES_DIR="$(pwd)/results/wma"

# === Dataset ===
# Comma-separated list of dataset names used during fine-tuning.
# Must match the checkpoint. For UnifoLM-WMA-0-Dual use the 5 training datasets.
DATASETS="G1_Pack_Camera"

# === Server ===
SERVER_PORT=8000
